SONIOX_API_KEY=your-soniox-api-key
AUTH_BEARER_TOKEN=
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
SONIOX_MODEL=stt-rt-v4
SONIOX_LANGUAGE_HINTS=en,pl
AUDIO_PASSTHROUGH=true
OMI_AUDIO_INPUT_FORMAT=webm
SONIOX_KEEPALIVE_INTERVAL_SECONDS=10
MAX_MESSAGE_BYTES=1048576
MAX_IDLE_SECONDS=120
MAX_CONCURRENT_STREAMS=100
